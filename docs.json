{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "apisale",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#6120EE",
    "light": "#C8F5EB",
    "dark": "#6120EE"
  },
  "navbar": {
    "links": [
      { "label": "Explore", "href": "https://apisale.ai/explore" },
      { "label": "Console", "href": "https://apisale.ai/console" },
      { "label": "API Keys", "href": "https://apisale.ai/console/api-keys" },
      { "label": "Pricing", "href": "https://apisale.ai/pricing" }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "https://apisale.ai/login"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "introduction",
          "get-started/quickstart",
          "get-started/authentication",
          "get-started/pricing",
          "get-started/webhooks",
          "get-started/errors-and-limits",
          "get-started/account-and-monitoring"
        ]
      },
      {
        "group": "Model APIs",
        "pages": [
          "model-apis/overview",
          "model-apis/submit-run",
          "model-apis/poll-runs",
          "model-apis/openai-compatible"
        ]
      },
      {
        "group": "API Reference",
        "openapi": "openapi.json"
      },
      {
        "group": "Platform APIs",
        "pages": [
          "platform/account",
          "platform/console-vs-public"
        ]
      },
      {
        "group": "Console Guide",
        "pages": [
          "console/overview",
          "console/limits",
          "console/api-keys",
          "console/billing"
        ]
      },
      {
        "group": "SDKs",
        "pages": ["sdks/overview"]
      }
    ]
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "autogenerate": true
    }
  }
}
